# API Keys for Form Function Platform
# Configure your form and integration APIs below

# Form Integration APIs (Zapier, Webhooks, etc.)
FORM_API_KEY="YOUR_FORM_API_KEY"

# Email Service Provider
EMAIL_API_KEY="YOUR_EMAIL_API_KEY"

# Application URL
APP_URL="http://localhost:3000"

# Database Configuration
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="formfunction_db"
DB_USER="formfunction_user"
DB_PASSWORD="your_secure_password"

# JWT Secret for Authentication
JWT_SECRET="your_jwt_secret_key_here"

# WebSocket Configuration
WS_PORT="3001"

# Environment
NODE_ENV="development"
